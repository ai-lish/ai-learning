{
  "name": "Solution Page Creation - Simple Migration",
  "description": "只搬運HTML + 加導航連結，唔改其他野",
  "steps": [
    {
      "step": 1,
      "name": "獲取 Email HTML",
      "description": "從 email 拎 raw HTML",
      "action": "gmail.get邮件.body"
    },
    {
      "step": 2,
      "name": "清理 HTML",
      "description": "移除 polyfill.io (如果有既話)",
      "action": "cleanHTML"
    },
    {
      "step": 3,
      "name": "加導航連結",
      "description": "只加返回按鈕 + 導航 link",
      "action": "addNavigationOnly"
    },
    {
      "step": 4,
      "name": "儲存檔案",
      "description": "save 到 p1-ms/qXX.html",
      "action": "saveFile"
    },
    {
      "step": 5,
      "name": "測試",
      "description": "HTTP 200 + Canvas 顯示",
      "action": "testPage"
    }
  ],
  "rules": {
    "禁止": [
      "修改 canvas JavaScript",
      "修改 resize code",
      "修改 MathJax config",
      "加 CSS 可能影響 layout"
    ],
    "只允許": [
      "加返回按鈕 (簡單 HTML)",
      "加導航連結",
      "移除壞既 CDN (polyfill.io)"
    ]
  }
}
