{
  "name": "Solution Page Test - Simple",
  "description": "簡單測試：HTTP + Canvas 存在，唔好整爛啲野",
  "testSteps": [
    {
      "step": 1,
      "name": "HTTP 測試",
      "description": "Check page returns 200",
      "check": "statusCode === 200"
    },
    {
      "step": 2,
      "name": "Canvas 存在",
      "description": "Check canvas element exists",
      "check": "html.includes('id=\"mathCanvas\"')"
    },
    {
      "step": 3,
      "name": "renderScene 函數",
      "description": "Check render function exists",
      "check": "html.includes('renderScene') || html.includes('drawVisualization')"
    },
    {
      "step": 4,
      "name": "導航連結",
      "description": "Check back link exists (optional)",
      "check": "html.includes('p1.html') || html.includes('../p1.html')"
    }
  ],
  "rules": {
    "禁止": [
      "Click 任何 button 測試 interaction",
      "修改任何 JavaScript",
      "檢查 MathJax render 結果 (會整爛啲野)"
    ],
    "只允許": [
      "HTTP HEAD/GET check",
      "String search for elements",
      "Check CDN resources accessible"
    ]
  }
}
