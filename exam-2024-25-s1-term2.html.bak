                    </div>
                    <div class="question">
                        <div class="question-header">
                            <span><span class="question-num">Q29</span>考慮多項式 $5x^2 + 6y - x + 3$。問以下哪個正確？</span>
                            <span class="question-score">1分</span>
                        </div>
                        <div class="question-content">
                            <strong>選項：</strong>需要睇圖
                        </div>
                        <div class="answer-section">
                            <div class="answer-label" onclick="toggleAnswer(this)">📖 顯示答案 ▼</div>
                            <div class="answer-content">
                                需要睇圖
                            </div>
                        </div>
                    </div>
                    <div class="question">
                        <div class="question-header">
                            <span><span class="question-num">Q30</span>展開 $(x-4)(x-2)$</span>
                            <span class="question-score">1分</span>
                        </div>
                        <div class="question-content">
                            <strong>選項：</strong><br>
                            A. $x^2 - 6x + 8$<br>
                            B. $x^2 + 6x + 8$<br>
                            C. $x^2 - 6x - 8$<br>
                            D. $x^2 + 6x - 8$
                        </div>
                        <div class="answer-section">
                            <div class="answer-label" onclick="toggleAnswer(this)">📖 顯示答案 ▼</div>
                            <div class="answer-content">
                                <strong>答案：A</strong><br>
                                $(x-4)(x-2) = x^2 - 2x - 4x + 8 = x^2 - 6x + 8$
                            </div>
                        </div>
                    </div>
                    <div class="question">
                        <div class="question-header">
                            <span><span class="question-num">Q29-Q40</span>選擇題：多項式、展開、應用題、幾何</span>
                            <span class="question-score">12分</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <script>
    function switchPaper(num) {
        // Remove all active classes from tabs and papers
        document.getElementById('tab1').classList.remove('active');
        document.getElementById('tab2').classList.remove('active');
        document.getElementById('paper1').classList.remove('active');
        document.getElementById('paper2').classList.remove('active');
        
        // Add active class to selected tab and paper
        document.getElementById('tab' + num).classList.add('active');
        document.getElementById('paper' + num).classList.add('active');
        
        // Scroll to top of paper
        document.getElementById('paper' + num).scrollIntoView({behavior: 'smooth'});
    }
    
    function showPaper(num) {
        document.querySelectorAll('.paper-tab').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.paper-content').forEach(p => p.classList.remove('active'));
        document.querySelectorAll('.paper-tab')[num-1].classList.add('active');
        document.getElementById('paper' + num).classList.add('active');
        
        if (window.MathJax) {
            MathJax.typesetPromise();
        }
    }
    
    function togglePart(header) {
        const content = header.nextElementSibling;
        content.classList.toggle('show');
    }
    
    function toggleAnswer(label) {
        const content = label.nextElementSibling;
        content.classList.toggle('show');
    }
    
    if (window.MathJax) {
        MathJax.typesetPromise();
    }
    </script>
</body>
</html>
